{
  "version": "1.0.0",
  "description": "Per-channel response formatting rules",
  "channels": {
    "telegram": {
      "max_length": 4096,
      "format": "markdown",
      "truncation": "smart",
      "footer": false,
      "code_blocks": true,
      "max_code_block_lines": 30
    },
    "slack": {
      "max_length": 3000,
      "format": "mrkdwn",
      "truncation": "smart",
      "footer": true,
      "code_blocks": true,
      "max_code_block_lines": 20
    },
    "discord": {
      "max_length": 2000,
      "format": "markdown",
      "truncation": "hard",
      "footer": false,
      "code_blocks": true,
      "max_code_block_lines": 15
    },
    "claude_code": {
      "max_length": null,
      "format": "markdown",
      "truncation": "none",
      "footer": false,
      "code_blocks": true,
      "max_code_block_lines": null
    }
  },
  "smart_truncation": {
    "strategy": "keep_structure",
    "preserve": ["headers", "bullet_points", "code_blocks"],
    "suffix": "\n\n[Response truncated — ask for more detail on any section]"
  }
}
