{
  "name": "jake-mcp-bridge",
  "version": "2.0.0",
  "description": "Bridges all MCP servers into OpenClaw as unified tools — Susan, Orchard, filesystem, and external services",
  "servers": {
    "susan": {
      "command": "python",
      "args": ["-m", "mcp_server.server"],
      "cwd": "/Users/michaelrodgers/Desktop/Startup-Intelligence-OS/susan-team-architect/backend",
      "env": { "PYTHONPATH": "." },
      "tools": ["susan_search", "susan_agent", "susan_foundry", "susan_research", "susan_roster", "susan_department"],
      "description": "Susan capability foundry — 218 agents, 10K+ RAG chunks, department routing"
    },
    "orchard": {
      "url": "http://localhost:8086/mcp",
      "tools": ["*"],
      "description": "Orchard MCP — 48 Apple ecosystem tools (Calendar, Contacts, Notes, Reminders, etc.)"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "tools": ["resolve-library-id", "get-library-docs"],
      "description": "Context7 — up-to-date library documentation retrieval"
    },
    "desktop-commander": {
      "command": "npx",
      "args": ["-y", "@anthropic/desktop-commander"],
      "tools": ["read_file", "write_file", "edit_block", "list_directory", "start_process", "interact_with_process"],
      "description": "Desktop Commander — file operations, process management, system control"
    },
    "scheduled-tasks": {
      "command": "npx",
      "args": ["-y", "@anthropic/scheduled-tasks"],
      "tools": ["create_scheduled_task", "list_scheduled_tasks", "update_scheduled_task"],
      "description": "Scheduled tasks — cron-like recurring and one-shot task execution"
    }
  },
  "routing": {
    "default_server": "susan",
    "intent_patterns": {
      "calendar|schedule|meeting|event": "orchard",
      "note|reminder|contact": "orchard",
      "library|docs|documentation|api reference": "context7",
      "file|directory|process|terminal": "desktop-commander",
      "schedule|recurring|cron|every": "scheduled-tasks",
      "research|agent|capability|foundry|department": "susan"
    }
  },
  "model_routing": {
    "default": "claude-sonnet-4-6",
    "reasoning_tasks": "claude-opus-4-6",
    "quick_tasks": "claude-haiku-4-5",
    "patterns": {
      "architecture|design|strategy|complex": "claude-opus-4-6",
      "search|lookup|list|status|simple": "claude-haiku-4-5",
      "code|build|test|debug|review": "claude-sonnet-4-6"
    }
  }
}
