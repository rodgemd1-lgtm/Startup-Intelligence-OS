{
  "name": "fabric-rest-sidecar",
  "version": "1.0.0",
  "description": "REST API wrapper for Fabric's 233 prompt patterns — exposes as HTTP endpoints for OpenClaw consumption",
  "host": "127.0.0.1",
  "port": 8080,
  "fabric_binary": "/usr/local/bin/fabric",
  "patterns_dir": "~/.config/fabric/patterns",
  "endpoints": {
    "/api/patterns": {
      "method": "GET",
      "description": "List all available Fabric patterns",
      "handler": "list_patterns"
    },
    "/api/run/:pattern": {
      "method": "POST",
      "description": "Run a specific Fabric pattern with input text",
      "handler": "run_pattern",
      "parameters": {
        "pattern": "string — pattern name (e.g., summarize, extract_wisdom, analyze_claims)",
        "input": "string — text to process",
        "model": "string — optional model override"
      }
    },
    "/api/health": {
      "method": "GET",
      "description": "Health check",
      "handler": "health_check"
    }
  },
  "frequently_used_patterns": {
    "summarize": { "alias": "s", "description": "Summarize input text", "model": "claude-haiku-4-5" },
    "extract_wisdom": { "alias": "w", "description": "Extract key insights and wisdom", "model": "claude-sonnet-4-6" },
    "analyze_claims": { "alias": "a", "description": "Analyze claims for validity", "model": "claude-sonnet-4-6" },
    "create_summary": { "description": "Create structured summary", "model": "claude-haiku-4-5" },
    "extract_article_wisdom": { "description": "Extract wisdom from articles", "model": "claude-sonnet-4-6" },
    "improve_prompt": { "description": "Improve a prompt", "model": "claude-sonnet-4-6" },
    "create_coding_project": { "description": "Generate project structure", "model": "claude-opus-4-6" },
    "analyze_paper": { "description": "Analyze research paper", "model": "claude-opus-4-6" },
    "rate_content": { "description": "Rate content quality", "model": "claude-sonnet-4-6" },
    "write_essay": { "description": "Write essay on topic", "model": "claude-opus-4-6" }
  },
  "model_defaults": {
    "quick_patterns": "claude-haiku-4-5",
    "standard_patterns": "claude-sonnet-4-6",
    "reasoning_patterns": "claude-opus-4-6"
  }
}
