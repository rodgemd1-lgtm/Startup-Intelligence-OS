PY
}

# ── debrief ───────────────────────────────────────────────────────────────────
print_debrief() {
    local operator="${1:-mike}"
python3 - "$operator" <<'PY'
import sys, json
from pathlib import Path

operator = sys.argv[1].lower()
if operator not in ('mike', 'susan'):
    operator = 'mike'

debrief_path = Path('apps/operator-console/operator-debrief.json')
if not debrief_path.exists():
    print('jake: no debrief available. Run bin/jake sync-intel first.', file=sys.stderr)
    sys.exit(1)

d = json.loads(debrief_path.read_text())
greeting = 'Hello, Susan' if operator == 'susan' else 'Hello, Mike'
print(f'\n{greeting} — Decision OS debrief\n')
print('Debrief:')
for item in d.get('debrief', []):
    print(f'  - {item}')
print(f'\nActions ({operator}):')
for item in d.get('actions', {}).get(operator, []):
    print(f'  1. {item}')
print('\nStatus:')
for item in d.get('status', []):
    print(f'  - {item}')
print()
PY
}

# ── claw <subcommand> ─────────────────────────────────────────────────────────
claw_control() {
    local subcmd="${1:-status}"
    shift 2>/dev/null || true
python3 - "$subcmd" "$@" <<'PY'
import json
import os
import sys

sys.path.insert(0, os.path.join(os.getcwd(), 'apps'))
from decision_os.claw_control import ClawControlPlane

control = ClawControlPlane()
subcmd = sys.argv[1]
args = sys.argv[2:]

def usage(exit_code: int = 2) -> None:
    print("Usage: bin/jake claw <onboard|status|sync|logs|eject|remote-brief|remote-command>", file=sys.stderr)
    print("", file=sys.stderr)
    print("Subcommands:", file=sys.stderr)
    print("  onboard [profile] [--force]   Seed control-plane profiles and registry", file=sys.stderr)
    print("  status [--json]               Show connector registry", file=sys.stderr)
    print("  sync [service ...]            Probe connectors and refresh bridge briefs", file=sys.stderr)
    print("  logs [limit]                  Show recent control-plane events", file=sys.stderr)
    print("  eject <service> [reason]      Disable a connector cleanly", file=sys.stderr)
    print("  remote-brief [--json]         Show the remote alert/intel feed for Mike Claw", file=sys.stderr)
    print("  remote-command <cmd> [args]   Run an allowlisted remote command", file=sys.stderr)
    sys.exit(exit_code)

if subcmd == "onboard":
    profile = "default"
    force = False
    for arg in args:
        if arg == "--force":
            force = True
        elif not arg.startswith("--"):
            profile = arg
    result = control.onboard(profile_id=profile, force=force)
    print("jake: claw onboard complete")
    print(f"  profile: {result['profile']}")
    print(f"  registry: {result['registry']}")
    print(f"  logs: {result['logs']}")
    print(f"  services: {result['service_count']}")
    if result["profiles_written"]:
        print("  profiles:")
        for path in result["profiles_written"]:
            print(f"    - {path}")
elif subcmd == "status":
    if "--json" in args:
        print(json.dumps(control.registry_payload(), indent=2))
    else:
        print(control.format_status_table())
elif subcmd == "sync":
    targets = [arg for arg in args if not arg.startswith("--")]
    result = control.sync(targets or None)
    print("jake: claw sync complete")
    if result["changes"]:
        print("  connector changes:")
        for change in result["changes"]:
            print(
                f"    - {change['service']}: mode {change['mode']}, state {change['state']}"
            )
    else:
        print("  connector changes: none")
    if result["generated_briefs"]:
        print("  generated briefs:")
        for brief in result["generated_briefs"]:
            print(f"    - {brief}")
elif subcmd == "logs":
    limit = 20
    if args:
        try:
            limit = int(args[0])
        except ValueError:
            usage()
    print(control.format_logs(limit=limit))
elif subcmd == "remote-brief":
    if "--json" in args:
        print(json.dumps(control.remote_brief(), indent=2))
    else:
        print(control.format_remote_brief())
elif subcmd == "remote-command":
    json_mode = "--json" in args
    command_args = [arg for arg in args if arg != "--json"]
    if not command_args:
        usage()
    result = control.remote_command(command_args[0], command_args[1:])
    if json_mode or not result["ok"]:
        print(json.dumps(result, indent=2))
        if not result["ok"]:
            sys.exit(2)
    else:
        print(json.dumps(result["result"], indent=2))
elif subcmd == "eject":
    if not args:
        usage()
    service = args[0]
    reason = " ".join(args[1:]).strip() or "manual eject"
    record = control.eject(service, reason=reason)
    print("jake: claw connector ejected")
    print(f"  service: {record.name}")
    print(f"  state: {record.state.value}")
    print(f"  reason: {record.last_error}")
else:
    usage()
PY
}

# ── smoke ─────────────────────────────────────────────────────────────────────
run_smoke() {
    echo "jake: running smoke test..."
    echo ""

    # 1. Check passes
    echo "Step 1: contract validation"
    run_checks || { echo "FAIL: checks did not pass"; exit 1; }
    echo ""

    # 2. Status works
    echo "Step 2: status"
    print_status
    echo ""

    # 3. Sync intel works
    echo "Step 3: sync-intel"
    sync_intel
    echo ""

    # 4. Context works
    echo "Step 4: os-context"
    "$ROOT_DIR/bin/os-context"
    echo ""

    # 5. Create and run a decision
    echo "Step 5: end-to-end decision pipeline"
python3 - <<'PY'
import sys, os
sys.path.insert(0, os.path.join(os.getcwd(), 'apps'))
try:
    from decision_os.store import Store
    from decision_os.decision_engine import DecisionEngine
    store = Store()
    engine = DecisionEngine(store)
    result = engine.run(
        title="Smoke test decision",
        context="Automated smoke test to verify end-to-end pipeline",
        company="founder-intelligence-os",
        assumptions=["System is operational"],
        risks=["Smoke test may not cover all edge cases"],
    )
    assert result.id, "Decision must have an ID"
    assert len(result.options) >= 3, "Must generate >= 3 options"
    assert len(result.debate_log) >= 5, "Must run all 5 debate modes"
    assert result.output.recommendation, "Must have recommendation"
    assert result.output.counter_recommendation, "Must have counter-recommendation"
    assert result.output.why_now, "Must have why_now"
    assert result.output.failure_modes, "Must have failure_modes"
    assert result.output.next_experiment, "Must have next_experiment"
    assert result.run_id, "Must have run_id"

    run = store.runs.get(result.run_id)
    assert run, "Run must be persisted"
    assert len(run.events) > 0, "Run must have events"

    # Cleanup smoke test artifacts
    store.decisions.delete(result.id)
    store.runs.delete(result.run_id)

    print('  decision pipeline: PASS')
    print(f'    options: {len(result.options)}, debates: {len(result.debate_log)}')
    print(f'    recommendation: {result.output.recommendation[:80]}...')
except Exception as e:
    print(f'  decision pipeline: FAIL ({e})')
    sys.exit(1)
PY
    echo ""
    echo "jake: smoke test PASSED"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "$cmd" in
    check|validate)
        run_checks
        ;;
    context)
        print_context
        ;;
    status)
        print_status
        ;;
    sync-intel)
        sync_intel
        ;;
    claw)
        claw_control "$@"
        ;;
    new)
        create_new "$@"
        ;;
    run-decision)
        run_decision "$@"
        ;;
    debate)
        run_debate "$@"
        ;;
    ingest-intel)
        ingest_intel
        ;;
    customer-studio)
        customer_studio "$@"
        ;;
    debrief)
        print_debrief "$@"
        ;;
    smoke)
        run_smoke
        ;;
    *)
        echo "Usage: bin/jake <command>"
        echo ""
        echo "Commands:"
        echo "  check|validate     Validate OS contract and critical assets"
        echo "  status             Print Decision OS object counts"
        echo "  sync-intel         Regenerate agent readiness index and operator debrief"
        echo "  claw              Claw hybrid control plane: onboard|status|sync|logs|eject|remote-brief|remote-command"
        echo "  context            Print active OS context (delegates to bin/os-context)"
        echo "  new <type>         Create a new decision|capability|project|run"
        echo "  run-decision <id>  Execute decision pipeline"
        echo "  debate <id>        Run debate cycle on existing decision"
        echo "  ingest-intel       Ingest intelligence from configured sources"
        echo "  customer-studio    Customer User Studio ops: seed|validate|report|push-susan|publish"
        echo "  debrief [operator] Show operator debrief (mike|susan)"
        echo "  smoke              Run end-to-end smoke test"
        exit 2
        ;;
esac
