{
  "mcpServers": {
    "orchard": {
      "url": "http://localhost:8086/mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "command": "bash bin/hooks/session-start.sh"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q 'claude-plugins/'; then echo 'BLOCK: Do not edit vendored plugin files in claude-plugins/' >&2; exit 2; fi; exit 0"
      },
      {
        "matcher": "Edit|Write",
        "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q 'susan-outputs/'; then echo 'BLOCK: susan-outputs/ is generated by Susan. Use /susan-plan to regenerate.' >&2; exit 2; fi; exit 0"
      },
      {
        "matcher": "Agent",
        "command": "bash bin/hooks/model-router.sh"
      },
      {
        "matcher": "Edit|Write",
        "command": "bash bin/hooks/research-first-gate.sh"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash bin/hooks/pre-compact.sh"
          }
        ],
        "description": "Save state before context compaction — logs event and annotates active session file"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "bash bin/hooks/quality-gate.sh"
      },
      {
        "matcher": "Agent",
        "command": "bash bin/hooks/confidence-tier.sh"
      },
      {
        "matcher": "Agent",
        "command": "bash bin/hooks/decision-audit.sh"
      },
      {
        "matcher": "Agent",
        "command": "bash bin/hooks/contradiction-detector.sh"
      },
      {
        "matcher": "Write",
        "command": "bash bin/hooks/autonomy-tracker.sh"
      }
    ],
    "Stop": [
      {
        "command": "bash bin/hooks/stop-gate.sh"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash bin/hooks/cost-tracker.sh",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Track token usage and estimated costs per session to ~/.claude/metrics/costs.jsonl"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash bin/hooks/brain-sync.sh",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Sync Claude Code memory files to Jake's shared Brain (Supabase) on session end"
      }
    ]
  }
}
